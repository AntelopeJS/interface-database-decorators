{
  "name": "@antelopejs/interface-database-decorators",
  "version": "0.0.1",
  "description": "AntelopeJS interface for database schema decorators and model definitions",
  "keywords": [
    "antelopejs",
    "interface",
    "database",
    "decorators",
    "orm"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AntelopeJS/interface-database-decorators.git"
  },
  "license": "Apache-2.0",
  "packageManager": "pnpm@10.6.5",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./*": {
      "types": "./dist/*.d.ts",
      "default": "./dist/*.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "rimraf dist && tsc",
    "format": "biome format --write .",
    "lint:fix": "biome check --write .",
    "lint": "biome check .",
    "prepack": "pnpm run build",
    "release": "pnpm run lint && pnpm run prepack && release-it",
    "test": "pnpm run build && ajs module test ."
  },
  "dependencies": {
    "@antelopejs/interface-api": "^0.0.2",
    "@antelopejs/interface-core": "^0.0.2",
    "@antelopejs/interface-database": "^0.0.2",
    "randomstring": "^1.3.1",
    "reflect-metadata": "^0.2.2"
  },
  "devDependencies": {
    "@types/chai": "^4.3.20",
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.14.1",
    "@types/randomstring": "^1.3.0",
    "@biomejs/biome": "2.3.2",
    "chai": "^4.5.0",
    "release-it": "^19.0.2",
    "release-it-changelogen": "^0.1.0",
    "rimraf": "^6.0.1",
    "typescript": "^5.8.3",
    "mongodb-memory-server-core": "^10.1.4",
    "@types/semver": "^7.7.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "typesVersions": {
    "*": {
      "common": [
        "dist/common.d.ts"
      ],
      "database": [
        "dist/database.d.ts"
      ],
      "model": [
        "dist/model.d.ts"
      ],
      "schema": [
        "dist/schema.d.ts"
      ],
      "table": [
        "dist/table.d.ts"
      ],
      "modifiers/common": [
        "dist/modifiers/common.d.ts"
      ],
      "modifiers/encryption": [
        "dist/modifiers/encryption.d.ts"
      ],
      "modifiers/hash": [
        "dist/modifiers/hash.d.ts"
      ],
      "modifiers/localization": [
        "dist/modifiers/localization.d.ts"
      ]
    }
  },
  "antelopeJs": {
    "test": "src/antelope.test.ts"
  }
}
